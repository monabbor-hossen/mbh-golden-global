<IfModule mod_rewrite.c>
    Options -Indexes -MultiViews
    RewriteEngine On

    # 1. ADMIN REDIRECT: Redirect /admin or /admin/ to /admin/login.php
    # This acts as the entry point since you don't want an index.php file.
    RewriteRule ^admin/?$ admin/login.php [L,QSA]

    # 2. Existing file/folder logic
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # 3. Clean URLs (.php extension)
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # 4. 404 Fallback
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ 404.php [L]
</IfModule>