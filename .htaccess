<IfModule mod_rewrite.c>
    Options -Indexes -MultiViews
    RewriteEngine On
    RewriteBase /mbh-golden-global/

    # 1. Clean URL Routing for SEO
    RewriteRule ^tour/([a-zA-Z0-9-]+)/?$ package-details.php?slug=$1 [L,QSA]
    RewriteRule ^story/([a-zA-Z0-9-]+)/?$ single-post.php?slug=$1 [L,QSA]

    # 2. Skip rewrite if the file/directory actually exists
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # 3. Handle standard .php removal
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # 4. Custom 404 Error
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ 404.php [L]
</IfModule>