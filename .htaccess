<IfModule mod_rewrite.c>
    Options -Indexes -MultiViews
    RewriteEngine On

    # 1. If the user requests an existing file or folder, load it normally
    RewriteCond %{REQUEST_FILENAME} -d [OR]
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # 2. If they request a clean URL (like /about), add .php ONLY if the file exists!
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # 3. THE MAGIC FIX: If the file DOES NOT exist, silently load 404.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ 404.php [L]
</IfModule>